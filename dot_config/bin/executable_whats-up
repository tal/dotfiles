#!/usr/bin/env zsh
# whats-up — quick system health overview with top resource hogs

set -uo pipefail

# ── Colors & formatting ──────────────────────────────────────────────
bold=$'\033[1m'
dim=$'\033[2m'
red=$'\033[31m'
yellow=$'\033[33m'
green=$'\033[32m'
cyan=$'\033[36m'
reset=$'\033[0m'
warn_marker=" ${yellow}⚠${reset}"

# ── Globals ──────────────────────────────────────────────────────────
cores=$(sysctl -n hw.ncpu)
typeset -A anomalies
typeset -a suggestions suggestion_commands suggestion_needs_sudo

# ── Argument parsing ─────────────────────────────────────────────────
cpu_min=0
mem_min=0
recent_mins=10
mode='snapshot'        # 'snapshot' | 'watch'
color_mode='on'        # 'on' | 'off'
action_mode='interactive'  # 'interactive' | 'off'

usage() {
  cat <<'EOF'
Usage: whats-up [OPTIONS]

Options:
  --cpu-min N     Only show processes using > N% CPU (default: 0)
  --mem-min N     Only show processes using > N% memory (default: 0)
  --watch         Run twice (5s apart) and show deltas
  --recent N      Show processes spawned in last N minutes (default: 10)
  --no-actions    Skip interactive suggestions
  --no-color      Disable color output
  --help          Show this help
EOF
}

parse_arguments() {
  local o_cpu_min o_mem_min o_watch o_recent o_no_actions o_no_color o_help

  zparseopts -D -E -F -- \
    -cpu-min:=o_cpu_min \
    -mem-min:=o_mem_min \
    -watch=o_watch \
    -recent:=o_recent \
    -no-actions=o_no_actions \
    -no-color=o_no_color \
    -help=o_help 2>/dev/null || { usage; exit 1; }

  [[ -n "${o_help[1]:-}" ]] && { usage; exit 0; }
  [[ -n "${o_cpu_min[1]:-}" ]] && cpu_min=${o_cpu_min[2]}
  [[ -n "${o_mem_min[1]:-}" ]] && mem_min=${o_mem_min[2]}
  [[ -n "${o_watch[1]:-}" ]] && mode='watch'
  [[ -n "${o_recent[1]:-}" ]] && recent_mins=${o_recent[2]}
  [[ -n "${o_no_actions[1]:-}" ]] && action_mode='off'
  [[ -n "${o_no_color[1]:-}" ]] && color_mode='off'

  if [[ "$color_mode" == 'off' ]]; then
    bold="" dim="" red="" yellow="" green="" cyan="" reset=""
    warn_marker=" ⚠"
  fi
}

# ── Gather system overview ───────────────────────────────────────────
read_top_summary() {
  top_output=$(top -l 1 -n 1 -stats pid,command,cpu 2>/dev/null)

  load_avg_raw=$(echo "$top_output" | grep "Load Avg" | sed 's/.*Load Avg: //')
  load_1=$(echo "$load_avg_raw" | cut -d',' -f1 | tr -d ' ')
  load_5=$(echo "$load_avg_raw" | cut -d',' -f2 | tr -d ' ')
  load_15=$(echo "$load_avg_raw" | cut -d',' -f3 | tr -d ' ')
  cpu_line=$(echo "$top_output" | grep "CPU usage")
  cpu_user=$(echo "$cpu_line" | sed 's/.*: \([0-9.]*\)% user.*/\1/')
  cpu_sys=$(echo "$cpu_line" | sed 's/.*user, \([0-9.]*\)% sys.*/\1/')
  cpu_idle=$(echo "$cpu_line" | sed 's/.*sys, \([0-9.]*\)% idle.*/\1/')

  phys_mem=$(echo "$top_output" | grep "PhysMem")
  mem_used=$(echo "$phys_mem" | sed 's/.*PhysMem: \([0-9A-Za-z]*\) used.*/\1/')
  mem_unused=$(echo "$phys_mem" | sed 's/.*, \([0-9A-Za-z]*\) unused.*/\1/')

  proc_line=$(echo "$top_output" | grep "Processes:")
  total_procs=$(echo "$proc_line" | sed 's/.*Processes: \([0-9]*\) total.*/\1/')
  running_procs=$(echo "$proc_line" | sed 's/.*, \([0-9]*\) running.*/\1/')

  swap_line=$(echo "$top_output" | grep "VM:")
  # Format: "9020767(0) swapins, 10742587(0) swapouts."
  swapins=$(echo "$swap_line" | sed 's/.*vsize, \([0-9]*\)(.*/\1/')
  swapouts=$(echo "$swap_line" | sed 's/.*swapins, \([0-9]*\)(.*/\1/')

  total_ram_bytes=$(sysctl -n hw.memsize)
  total_ram_gb=$(echo "scale=0; $total_ram_bytes / 1073741824" | bc)

  pressure=$(memory_pressure 2>/dev/null | tail -1 | sed 's/.*: //' || echo "unknown")
}

# ── Gather aggregated per-process data ───────────────────────────────
# Walks each process up to its root ancestor (parent of PID 0 or 1),
# then sums CPU, MEM, and RSS under that ancestor.
# Output: TAB-separated lines: PID \t CPU \t MEM \t RSS \t COUNT \t BASENAME \t FULL_ARGS
get_aggregated_processes() {
  ps -Ao pid=,ppid=,pcpu=,pmem=,rss=,args= | awk '
  {
    pid = $1; ppid = $2; cpu = $3; mem = $4; rss = $5
    args = ""; for (i = 6; i <= NF; i++) args = (args == "" ? $i : args " " $i)

    # Extract basename from the binary (first word of args)
    bn = $6; sub(/.*\//, "", bn)

    par[pid] = ppid; cpu_v[pid] = cpu+0; mem_v[pid] = mem+0; rss_v[pid] = rss+0
    base[pid] = bn; full[pid] = args

    # Detect transparent processes (terminal emulators, tmux, shells)
    if (bn ~ /^(ghostty|iTerm2|Terminal|Alacritty|kitty|WezTerm|tmux|tmux-client|login|sshd|bash|zsh|sh|fish)$/) {
      transparent[pid] = 1
    }
  }
  END {
    for (pid in par) {
      a = pid; n = 0
      while ((a in par) && par[a]+0 > 1 && n < 20) {
        if (par[a] in transparent) break
        a = par[a]; n++
      }
      agg_cpu[a] += cpu_v[pid]
      agg_mem[a] += mem_v[pid]
      agg_rss[a] += rss_v[pid]
      agg_cnt[a]++
    }
    for (a in agg_cpu) {
      if (agg_cpu[a] > 0.1 || agg_rss[a] > 10240) {
        printf "%s\t%.1f\t%.1f\t%d\t%d\t%s\t%s\n", a, agg_cpu[a], agg_mem[a], agg_rss[a], agg_cnt[a], base[a], full[a]
      }
    }
  }'
}

# ── Helpers ──────────────────────────────────────────────────────────
human_bytes() {
  local kb=$1
  if [ "$kb" -ge 1048576 ]; then
    echo "$(echo "scale=1; $kb / 1048576" | bc)G"
  elif [ "$kb" -ge 1024 ]; then
    echo "$(echo "scale=0; $kb / 1024" | bc)M"
  else
    echo "${kb}K"
  fi
}

human_number() {
  local n=$1
  if [ "$n" -ge 1000000 ]; then
    echo "$(echo "scale=1; $n / 1000000" | bc)M"
  elif [ "$n" -ge 1000 ]; then
    echo "$(echo "scale=1; $n / 1000" | bc)K"
  else
    echo "$n"
  fi
}

short_name() {
  basename "$1" 2>/dev/null || echo "$1"
}

